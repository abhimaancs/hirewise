# Supabase - get these from supabase.com > your project > Settings > API
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Anthropic - get from console.anthropic.com
# Used by: /api/parse-resume, /api/cover-letter
ANTHROPIC_API_KEY=your_anthropic_api_key

# OpenRouter - get from openrouter.ai/keys
# Used by: /api/match-jobs, /api/match-candidates (Mistral via OpenRouter)
# Without this key, AI matching silently falls back to basic skill scoring.
OPENROUTER_API_KEY=your_openrouter_api_key
